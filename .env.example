# Copy this file to .env and fill in your real values. NEVER commit .env.
# Get your QRZ API key at: https://logbook.qrz.com/logbook?op=keys
QRZ_API_KEY=your_qrz_logbook_api_key_here

# Optional: override JARL rate limit (seconds between requests).
# Default 1.0 — be nice to JARL.
JARL_RATE_LIMIT_SECONDS=1.0

# Optional: cache TTL in days. Default 30.
CACHE_TTL_DAYS=30
